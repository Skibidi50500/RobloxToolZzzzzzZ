-- Wait for game to load
if not game:IsLoaded() then game.Loaded:Wait() end

-- Services
local Players, UserInputService, RunService, TweenService, Stats = 
    game:GetService("Players"), 
    game:GetService("UserInputService"),
    game:GetService("RunService"),
    game:GetService("TweenService"),
    game:GetService("Stats")

-- Get Player and PlayerGui
local player = Players.LocalPlayer
while not player do player = Players.LocalPlayer task.wait() end
local playerGui = player:WaitForChild("PlayerGui")

-- Storage (To store MiniStats info)
_G.MiniStats = _G.MiniStats or {injectCount = 0, connections = {}, hasLoadedOnce = false}
local storage = _G.MiniStats
storage.injectCount = storage.injectCount + 1

-- Disconnect old connections
for _, c in ipairs(storage.connections) do
    if c and c.Disconnect then c:Disconnect() end
end
table.clear(storage.connections)

-- Clean up old UI components before creating new ones
if playerGui:FindFirstChild("MiniStats") then playerGui.MiniStats:Destroy() end
if playerGui:FindFirstChild("MiniNotify") then playerGui.MiniNotify:Destroy() end

-- Settings
local LOW_FPS, loadDuration, loadStart = 30, math.random(3, 5), os.clock()
local startupFinished, capped, counterVisible = false, false, true

-- Notify System (Standard Roblox notifications)
local function sendRobloxNotification(title, text, duration)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = title,
        Text = text,
        Icon = "",
        Duration = duration or 5
    })
end

-- Loading notification (shown only once when script is injected)
if not storage.hasLoadedOnce then
    sendRobloxNotification("Loading", "Please wait " .. loadDuration .. " seconds while the script is loading.", loadDuration)
end

-- Counter GUI (For FPS and Ping)
local gui, label = Instance.new("ScreenGui"), Instance.new("TextLabel")
gui.Name, gui.IgnoreGuiInset, gui.ResetOnSpawn, gui.Parent = "MiniStats", true, false, playerGui
label.AnchorPoint, label.Position, label.Size, label.BackgroundTransparency, label.Font, label.TextSize, label.RichText, label.TextWrapped, label.TextXAlignment, label.TextYAlignment = 
    Vector2.new(0, 1), UDim2.new(0, 8, 1, -8), UDim2.fromOffset(220, 65), 1, Enum.Font.GothamBold, 19, true, true, Enum.TextXAlignment.Left, Enum.TextYAlignment.Bottom
label.Parent = gui
local stroke = Instance.new("UIStroke", label)
stroke.Thickness, stroke.Color = 1.4, Color3.new(0, 0, 0)

-- FPS and Ping color functions
local function fpsColor(v) return v < 20 and "255,0,0" or v < 30 and "255,140,0" or v < 50 and "255,215,0" or "0,255,0" end
local function pingColor(v) return v < 45 and "0,255,0" or v < 65 and "255,215,0" or v < 130 and "255,140,0" or "255,0,0" end

-- Keybinds
table.insert(storage.connections, UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.T then
        counterVisible = not counterVisible
        label.Visible = counterVisible
        -- No custom notification here anymore
    elseif input.KeyCode == Enum.KeyCode.R then
        if setfpscap then
            capped = not capped
            setfpscap(capped and LOW_FPS or 0)
        end
    end
end))

-- Render loop (FPS and Ping calculations)
local frames, fps, last, dotState, dotTimer = 0, 0, os.clock(), 0, 0
local isCounting = true  -- Variable to track if we should update FPS and Ping

table.insert(storage.connections, RunService.RenderStepped:Connect(function(delta)
    -- Only calculate FPS and Ping when counterVisible is true
    if counterVisible then
        if isCounting then
            frames = frames + 1

            -- Update FPS once per second
            if os.clock() - last >= 1 then
                fps = frames
                frames = 0
                last = os.clock()
            end

            -- Loading placeholder
            if not startupFinished then
                dotTimer = dotTimer + delta
                if dotTimer >= 0.4 then dotTimer = 0 dotState = (dotState % 3) + 1 end
                local dots = string.rep(".", dotState)

                label.Text = "<font color='rgb(255,255,255)'>LOADING FPS" .. dots .. "</font>\n" .. "<font color='rgb(255,255,255)'>LOADING PING" .. dots .. "</font>"

                -- After loading time, show "Successfully Loaded" and "Controls"
                if os.clock() - loadStart >= loadDuration then
                    startupFinished = true
                    storage.hasLoadedOnce = true
                    sendRobloxNotification("Loaded Successfully", "The script is now running.", 4)

                    -- Print the instructions to the console
                    print("Successfully loaded")
                    print("Press [ R ] = Toggle FPS Cap (30)")
                    print("Press [ T ] - Show / Hide counter")

                    task.delay(0.2, function() 
                        sendRobloxNotification("Controls", "[ R ] - Toggle FPS Cap (30)\n[ T ] - Show / Hide counter", 6) 
                    end)

                    -- Hide notifications after 15 seconds
                    task.delay(15, function() playerGui:FindFirstChild("MiniNotify"):Destroy() end)
                end
                return
            end
        end
    end

    -- Real Ping from Stats
    local ping = 0
    local item = Stats.Network.ServerStatsItem["Data Ping"]
    if item then ping = math.floor(item:GetValue()) end

    -- Update FPS and Ping counter
    label.Text =
        "<font color='rgb("..fpsColor(fps)..")'>"..fps.." FPS</font>\n".. 
        "<font color='rgb("..pingColor(ping)..")'>"..ping.." ms</font>"
end))

-- Inject count notification (if script was injected more than once)
if storage.injectCount > 1 then
    sendRobloxNotification("Inject Count", "Script injected " .. storage.injectCount .. " times.", 4)
end
