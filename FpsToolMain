if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Prevent duplicate execution
if rawget(_G, "__FPS_TOOL_LOADED__") then
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "FPS Tool",
            Text = "Already running",
            Duration = 5
        })
    end)
    return
end
_G.__FPS_TOOL_LOADED__ = true

-- Services
local Players = game:GetService("Players")
local Input = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")

local LocalPlayer = Players.LocalPlayer

-- Default configuration
local DEFAULT = {
    ToggleKey = Enum.KeyCode.R,
    LowFPS = 30,
    MaxFPS = 240
}

-- User configuration
local USER = getgenv().FPS_CONFIG or {}

-- Resolved configuration
local CONFIG = {
    ToggleKey = USER.ToggleKey or DEFAULT.ToggleKey,
    LowFPS = tonumber(USER.LowFPS) or DEFAULT.LowFPS,
    MaxFPS = tonumber(USER.MaxFPS) or DEFAULT.MaxFPS
}

-- Internal state
local isLimited = false
local currentCap = nil

-- Notification utility
local function notify(title, message, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = message,
            Duration = duration or 5
        })
    end)
end

-- Optimized FPS setter
local function setCap(value)
    if typeof(setfpscap) == "function" then
        if currentCap ~= value then
            currentCap = value
            setfpscap(value)
        end
    end
end

-- Apply current mode
local function apply()
    if isLimited then
        setCap(CONFIG.LowFPS)
    else
        setCap(CONFIG.MaxFPS)
    end
end

-- Toggle handler
local function toggle()
    isLimited = not isLimited
    apply()
end

-- Input handling
Input.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if input.KeyCode ~= CONFIG.ToggleKey then return end

    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return end
    if gui:FindFirstChild("Chat") or gui:FindFirstChild("MenuGui") then return end

    toggle()
end)

-- Reset on respawn
LocalPlayer.CharacterAdded:Connect(function()
    isLimited = false
    apply()
end)

-- Init
apply()

-- Startup notifications sequentially (10s each)
task.spawn(function()
    notify("FPS Tool", "Loaded successfully", 10)
    task.wait(1)
    notify("Controls", "[" .. CONFIG.ToggleKey.Name .. "] - to toggle FPS", 10)
    task.wait(1)
    notify("Settings", "Max FPS: " .. CONFIG.MaxFPS .. "\nLow FPS (When toggle ON): " .. CONFIG.LowFPS, 10)
end)
