-- Wait for game to load
if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Services
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")

local LP = Players.LocalPlayer

-- Default config
local DEFAULT = {
    ToggleKey = Enum.KeyCode.R,
    LowFPS = 30,
    MaxFPS = 240
}

-- Get user config
local USER = getgenv().FPS_CONFIG or {}

local NEW_CONFIG = {
    ToggleKey = USER.ToggleKey or DEFAULT.ToggleKey,
    LowFPS = tonumber(USER.LowFPS) or DEFAULT.LowFPS,
    MaxFPS = tonumber(USER.MaxFPS) or DEFAULT.MaxFPS
}

-- Notification function
local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration or 4
        })
    end)
end

-- Compare configs
local function isSameConfig(a, b)
    return a.ToggleKey == b.ToggleKey
        and a.LowFPS == b.LowFPS
        and a.MaxFPS == b.MaxFPS
end

-- Format settings text
local function formatSettings(cfg)
    return "Keybind: " .. cfg.ToggleKey.Name ..
           "\nMax FPS: " .. cfg.MaxFPS ..
           "\nLow FPS: " .. cfg.LowFPS
end

-- Check if already running
if rawget(_G, "__FPS_TOOL_STATE__") then
    local STATE = _G.__FPS_TOOL_STATE__
    local old = STATE.CONFIG

    if isSameConfig(old, NEW_CONFIG) then
        notify("FPS Tool", "Already running", 5)
        return
    end

    notify("FPS Tool", "Applying new settings...", 2)

    STATE.CONFIG = NEW_CONFIG
    STATE.apply()

    task.delay(math.random(1, 2), function()
        notify("FPS Tool", "Applied new settings", 3)

        notify(
            "New Settings",
            formatSettings(NEW_CONFIG),
            6
        )
    end)

    return
end

-- First load
_G.__FPS_TOOL_STATE__ = {}
local STATE = _G.__FPS_TOOL_STATE__

STATE.CONFIG = NEW_CONFIG

local isLimited = false
local currentCap = nil

-- Safe FPS cap setter
local function setCap(cap)
    if typeof(setfpscap) ~= "function" then return end
    if currentCap == cap then return end

    currentCap = cap

    -- Wait one frame to avoid spikes
    RunService.Heartbeat:Wait()

    pcall(setfpscap, cap)
end

-- Apply FPS state
function STATE.apply()
    local CONFIG = STATE.CONFIG

    if isLimited then
        setCap(CONFIG.LowFPS)
    else
        setCap(CONFIG.MaxFPS)
    end
end

-- Toggle FPS (no cooldown)
local function toggle()
    isLimited = not isLimited
    STATE.apply()
end

-- Input listener
UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if input.KeyCode ~= STATE.CONFIG.ToggleKey then return end

    toggle()
end)

-- Reset to max FPS on respawn
LP.CharacterAdded:Connect(function()
    isLimited = false
    task.wait(0.5)
    STATE.apply()
end)

-- Initial apply
STATE.apply()

-- Startup notifications
task.spawn(function()
    notify("FPS Tool", "Loaded successfully", 10)
    task.wait(1)

    notify(
        "Current Settings",
        formatSettings(STATE.CONFIG),
        10
    )
end)
