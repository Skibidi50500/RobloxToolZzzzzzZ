-- Wait game load
if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Prevent duplicate
if rawget(_G, "__FPS_TOOL_LOADED__") then
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "FPS Tool",
            Text = "Already running",
            Duration = 5
        })
    end)
    return
end
_G.__FPS_TOOL_LOADED__ = true

-- Services
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")

local LP = Players.LocalPlayer

-- Default
local DEFAULT = {
    ToggleKey = Enum.KeyCode.R,
    LowFPS = 30,
    MaxFPS = 240,
    AFKTime = 0
}

-- User config
local USER = getgenv().FPS_CONFIG or {}

local CONFIG = {
    ToggleKey = USER.ToggleKey or DEFAULT.ToggleKey,
    LowFPS = tonumber(USER.LowFPS) or DEFAULT.LowFPS,
    MaxFPS = tonumber(USER.MaxFPS) or DEFAULT.MaxFPS,
    AFKTime = tonumber(USER.AFKTime) or DEFAULT.AFKTime
}

-- State
local isLimited = false
local currentCap = nil
local lastInputTime = tick()
local isAFK = false
local debounce = false

-- Notify
local function notify(t, msg, d)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = t,
            Text = msg,
            Duration = d or 5
        })
    end)
end

-- Safe fps cap (anti spike)
local function setCap(cap)
    if typeof(setfpscap) ~= "function" then return end
    if currentCap == cap then return end

    currentCap = cap

    -- tránh spike
    RunService.Heartbeat:Wait()

    pcall(setfpscap, cap)
end

-- Apply logic
local function apply()
    if isAFK then
        setCap(CONFIG.LowFPS)
        return
    end

    if isLimited then
        setCap(CONFIG.LowFPS)
    else
        setCap(CONFIG.MaxFPS)
    end
end

-- Toggle
local function toggle()
    if debounce then return end
    debounce = true

    isLimited = not isLimited
    apply()

    notify("FPS Tool", isLimited and ("Low FPS: "..CONFIG.LowFPS) or ("Max FPS: "..CONFIG.MaxFPS), 4)

    task.delay(0.2, function()
        debounce = false
    end)
end

-- Input detect
UIS.InputBegan:Connect(function(input, gp)
    if not gp then
        lastInputTime = tick()

        if isAFK then
            isAFK = false
            apply()
            notify("AFK", "Back to normal FPS", 4)
        end
    end

    if gp then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if input.KeyCode ~= CONFIG.ToggleKey then return end

    toggle()
end)

-- AFK checker
if CONFIG.AFKTime > 0 then
    task.spawn(function()
        while true do
            task.wait(1)

            if not isAFK and (tick() - lastInputTime >= CONFIG.AFKTime) then
                isAFK = true
                apply()
                notify("AFK", "FPS reduced ("..CONFIG.LowFPS..")", 4)
            end
        end
    end)
end

-- Respawn
LP.CharacterAdded:Connect(function()
    task.wait(0.5)
    apply()
end)

-- Init
apply()

-- 🔥 Startup notifications (GIỮ NGUYÊN + FIX)
task.spawn(function()
    notify("FPS Tool", "Loaded successfully", 10)
    task.wait(1)

    notify("Controls", "[" .. CONFIG.ToggleKey.Name .. "] - to toggle FPS", 10)
    task.wait(1)

    notify("Settings", "Max FPS: " .. CONFIG.MaxFPS .. "\nLow FPS (When toggle ON): " .. CONFIG.LowFPS, 10)
    task.wait(1)

    -- ✅ AFK Notify (NEW - theo yêu cầu)
    if CONFIG.AFKTime > 0 then
        notify(
            "AFK ENABLED",
            "If you do not interact for "..CONFIG.AFKTime.." seconds, you will be switched to AFK mode",
            10
        )
    end
end)
