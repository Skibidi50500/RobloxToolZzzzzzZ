-- Wait game load
if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Prevent duplicate
if rawget(_G, "__FPS_TOOL_LOADED__") then
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "FPS Tool",
            Text = "Already running",
            Duration = 5
        })
    end)
    return
end
_G.__FPS_TOOL_LOADED__ = true

-- Services
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")

local LP = Players.LocalPlayer

-- Default
local DEFAULT = {
    ToggleKey = Enum.KeyCode.R,
    LowFPS = 30,
    MaxFPS = 240
}

-- User config
local USER = getgenv().FPS_CONFIG or {}

local CONFIG = {
    ToggleKey = USER.ToggleKey or DEFAULT.ToggleKey,
    LowFPS = tonumber(USER.LowFPS) or DEFAULT.LowFPS,
    MaxFPS = tonumber(USER.MaxFPS) or DEFAULT.MaxFPS
}

-- State
local isLimited = false
local currentCap = nil
local debounce = false

-- Notify
local function notify(t, msg, d)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = t,
            Text = msg,
            Duration = d or 5
        })
    end)
end

-- Safe fps cap (anti spike)
local function setCap(cap)
    if typeof(setfpscap) ~= "function" then return end
    if currentCap == cap then return end

    currentCap = cap

    -- tránh spike
    RunService.Heartbeat:Wait()

    pcall(setfpscap, cap)
end

-- Apply
local function apply()
    if isLimited then
        setCap(CONFIG.LowFPS)
    else
        setCap(CONFIG.MaxFPS)
    end
end

-- Toggle (KHÔNG notify)
local function toggle()
    if debounce then return end
    debounce = true

    isLimited = not isLimited
    apply()

    task.delay(0.2, function()
        debounce = false
    end)
end

-- Input
UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if input.KeyCode ~= CONFIG.ToggleKey then return end

    toggle()
end)

-- Respawn
LP.CharacterAdded:Connect(function()
    task.wait(0.5)
    apply()
end)

-- Init
apply()

-- Startup notifications (giữ lại)
task.spawn(function()
    notify("FPS Tool", "Loaded successfully", 10)
    task.wait(1)

    notify("Controls", "[" .. CONFIG.ToggleKey.Name .. "] - to toggle FPS", 10)
    task.wait(1)

    notify("Settings", "Max FPS: " .. CONFIG.MaxFPS .. "\nLow FPS (When toggle ON): " .. CONFIG.LowFPS, 10)
end)
