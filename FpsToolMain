-- Wait game load
if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Services
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")

local LP = Players.LocalPlayer

-- Default
local DEFAULT = {
    ToggleKey = Enum.KeyCode.R,
    LowFPS = 30,
    MaxFPS = 240
}

-- User config
local USER = getgenv().FPS_CONFIG or {}

local NEW_CONFIG = {
    ToggleKey = USER.ToggleKey or DEFAULT.ToggleKey,
    LowFPS = tonumber(USER.LowFPS) or DEFAULT.LowFPS,
    MaxFPS = tonumber(USER.MaxFPS) or DEFAULT.MaxFPS
}

-- Notify
local function notify(t, msg, d)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = t,
            Text = msg,
            Duration = d or 4
        })
    end)
end

-- So sánh config
local function isSameConfig(a, b)
    return a.ToggleKey == b.ToggleKey
        and a.LowFPS == b.LowFPS
        and a.MaxFPS == b.MaxFPS
end

-- Format settings text
local function formatSettings(cfg, includeKey)
    local text = "Max FPS: "..cfg.MaxFPS.."\nLow FPS: "..cfg.LowFPS
    if includeKey then
        text = text .. "\nKeybind: " .. cfg.ToggleKey.Name
    end
    return text
end

-- Nếu đã chạy
if rawget(_G, "__FPS_TOOL_STATE__") then
    local STATE = _G.__FPS_TOOL_STATE__
    local old = STATE.CONFIG

    if isSameConfig(old, NEW_CONFIG) then
        notify("FPS Tool", "Already running", 5)
        return
    end

    -- check có đổi key không
    local keyChanged = old.ToggleKey ~= NEW_CONFIG.ToggleKey

    notify("FPS Tool", "Applying new settings...", 2)

    -- update config
    STATE.CONFIG = NEW_CONFIG
    STATE.apply()

    -- Applied + show new settings
    task.delay(math.random(1,2), function()
        notify("FPS Tool", "Applied new settings", 3)

        notify(
            "FPS Tool",
            formatSettings(NEW_CONFIG, keyChanged),
            6
        )
    end)

    return
end

-- ===== FIRST LOAD =====

_G.__FPS_TOOL_STATE__ = {}
local STATE = _G.__FPS_TOOL_STATE__

STATE.CONFIG = NEW_CONFIG

local isLimited = false
local currentCap = nil
local debounce = false

-- Safe cap
local function setCap(cap)
    if typeof(setfpscap) ~= "function" then return end
    if currentCap == cap then return end

    currentCap = cap
    RunService.Heartbeat:Wait()
    pcall(setfpscap, cap)
end

-- Apply
function STATE.apply()
    local CONFIG = STATE.CONFIG

    if isLimited then
        setCap(CONFIG.LowFPS)
    else
        setCap(CONFIG.MaxFPS)
    end
end

-- Toggle
local function toggle()
    if debounce then return end
    debounce = true

    isLimited = not isLimited
    STATE.apply()

    task.delay(0.2, function()
        debounce = false
    end)
end

-- Input
UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if input.KeyCode ~= STATE.CONFIG.ToggleKey then return end

    toggle()
end)

-- Respawn
LP.CharacterAdded:Connect(function()
    task.wait(0.5)
    STATE.apply()
end)

-- Init
STATE.apply()

-- Startup notify
task.spawn(function()
    notify("FPS Tool", "Loaded successfully", 10)
    task.wait(1)

    notify("Controls", "[" .. STATE.CONFIG.ToggleKey.Name .. "] - to toggle FPS", 10)
    task.wait(1)

    notify(
        "Current Settings",
        formatSettings(STATE.CONFIG, true),
        10
    )
end)
