-- Wait game load
if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Prevent duplicate
if rawget(_G, "__FPS_TOOL_LOADED__") then return end
_G.__FPS_TOOL_LOADED__ = true

-- Services
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")

local LP = Players.LocalPlayer

-- Default
local DEFAULT = {
    ToggleKey = Enum.KeyCode.R,
    LowFPS = 30,
    MaxFPS = 240,
    AFKTime = 0
}

-- User config
local USER = getgenv().FPS_CONFIG or {}

local CONFIG = {
    ToggleKey = USER.ToggleKey or DEFAULT.ToggleKey,
    LowFPS = tonumber(USER.LowFPS) or DEFAULT.LowFPS,
    MaxFPS = tonumber(USER.MaxFPS) or DEFAULT.MaxFPS,
    AFKTime = tonumber(USER.AFKTime) or DEFAULT.AFKTime
}

-- State
local isLimited = false
local currentCap = nil
local lastInputTime = tick()
local isAFK = false
local debounce = false

-- Notify
local function notify(t, msg, d)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = t,
            Text = msg,
            Duration = d or 4
        })
    end)
end

-- Safe fps cap (NO SPIKE VERSION)
local function setCap(cap)
    if typeof(setfpscap) ~= "function" then return end
    if currentCap == cap then return end

    currentCap = cap

    -- cực quan trọng: delay 1 frame để tránh drop
    RunService.Heartbeat:Wait()

    pcall(setfpscap, cap)
end

-- Apply logic (ưu tiên AFK)
local function apply()
    if isAFK then
        setCap(CONFIG.LowFPS)
        return
    end

    if isLimited then
        setCap(CONFIG.LowFPS)
    else
        setCap(CONFIG.MaxFPS)
    end
end

-- Toggle
local function toggle()
    if debounce then return end
    debounce = true

    isLimited = not isLimited
    apply()

    notify("FPS Tool", isLimited and ("Low FPS: "..CONFIG.LowFPS) or ("Max FPS: "..CONFIG.MaxFPS))

    task.delay(0.2, function()
        debounce = false
    end)
end

-- Detect input (reset AFK)
UIS.InputBegan:Connect(function(input, gp)
    if not gp then
        lastInputTime = tick()

        if isAFK then
            isAFK = false
            apply()
            notify("AFK", "Back to normal FPS")
        end
    end

    if gp then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if input.KeyCode ~= CONFIG.ToggleKey then return end

    toggle()
end)

-- AFK checker (ULTRA LIGHT - không gây lag)
if CONFIG.AFKTime > 0 then
    task.spawn(function()
        while true do
            task.wait(1)

            if not isAFK and (tick() - lastInputTime >= CONFIG.AFKTime) then
                isAFK = true
                apply()
                notify("AFK", "FPS reduced ("..CONFIG.LowFPS..")")
            end
        end
    end)
end

-- Respawn fix (KHÔNG gây spike)
LP.CharacterAdded:Connect(function()
    task.wait(0.5)
    apply()
end)

-- Init
apply()

notify("FPS Tool", "Loaded | AFK: "..CONFIG.AFKTime.."s")
