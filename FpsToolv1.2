-- Wait for game to load
if not game:IsLoaded() then game.Loaded:Wait() end

-- Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")

-- Initialize storage safely
_G.MiniStats = _G.MiniStats or {injectCount = 0, connections = {}}
local storage = _G.MiniStats
storage.injectCount = storage.injectCount + 1

-- Send Notification
local function sendNotification(title, text, duration)
    StarterGui:SetCore("SendNotification", {Title = title, Text = text, Duration = duration or 5})
end

-- FPS Toggle (R key)
local capped = false
local canToggleFPS = false  -- Flag to lock/unlock FPS toggle

local function handleKeyInput(input)
    if not canToggleFPS then return end  -- Ignore input if loading
    if input.KeyCode == Enum.KeyCode.R then
        setfpscap(capped and 0 or 30)
        capped = not capped
    end
end

-- Loading Process
local loadDuration = math.random(3, 5)
sendNotification("Loading Script", "Please wait " .. loadDuration .. " seconds.", loadDuration)
local loadStart = os.clock()

-- Flag for completed loading
local loadingCompleted = false

-- Render Loop
local renderConnection
renderConnection = RunService.RenderStepped:Connect(function()
    if os.clock() - loadStart >= loadDuration then
        -- Allow FPS toggle after loading completes
        canToggleFPS = true
        sendNotification("Loaded", "The script is now running.", 4)
        print("Successfully loaded. Press [R] to toggle FPS cap.")
        sendNotification("Controls", "[R] - Toggle FPS cap (30)", 4)

        -- Disconnect the render loop after loading
        renderConnection:Disconnect()
        loadingCompleted = true
    end
end)

-- Input Handler
UserInputService.InputBegan:Connect(handleKeyInput)
