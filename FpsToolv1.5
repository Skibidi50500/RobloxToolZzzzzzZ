if not game:IsLoaded() then game.Loaded:Wait() end
local UI, RS, STG = game:GetService("UserInputService"), game:GetService("RunService"), game:GetService("StarterGui")
_G.MiniStats = (_G.MiniStats or {injectCount = 0}); _G.MiniStats.injectCount += 1

local loaded, cap, toggle = false, 120, false

local function notify(t, m, d)
    pcall(function() STG:SetCore("SendNotification", {Title = t, Text = m, Duration = d or 5}) end)
end

notify("Loading Script", ("Please wait %ds."):format(math.random(3, 5)), 5)

local t0 = os.clock()
RS.RenderStepped:Connect(function()
    if not loaded and os.clock() - t0 >= 5 then
        loaded = true
        notify("Loaded", "The script is now running.", 4)
        notify("Controls", "[R] - Toggle FPS cap (30)", 4)
    end
end)

UI.InputBegan:Connect(function(i)
    if loaded and i.UserInputType == Enum.UserInputType.Keyboard and i.KeyCode == Enum.KeyCode.R then
        toggle = not toggle
        setfpscap(toggle and 30 or cap)
    end
end)
